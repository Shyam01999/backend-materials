PORT = 8080
NODE_ENV = development

BACKEND_URL = 'https://example.com'

# local db credentials
LOCAL_DB_USERNAME = postgres
LOCAL_DB_PASSWORD = 123456
LOCAL_DB_NAME = LMS_DB
LOCAL_DB_HOST = localhost
LOCAL_DB_PORT = 5432 
LOCAL_DB_LOGGING = false
LOCAL_DB_DIALECT = postgres
LOCAL_DB_SSL= true 
LOCAL_DB_SSLREQUIRE = true 
LOCAL_DB_SSLREJECTUNAUTHORIZED = false


