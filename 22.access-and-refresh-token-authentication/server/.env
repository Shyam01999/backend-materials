#jwt info
JWT_ACCESS_SECRET_KEY = donotsharethiskeywithanybody
JWT_REFRESH_SECRET_KEY = neversharethiskeyrefreshwithanybody
ACCESS_TOKEN_EXPIRES =1m
REFRESH_TOKEN_EXPIRES =7d

#cookie info
HTTP_ONLY=true
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_ACCESS_TOKEN_EXPIRES=1
COOKIE_REFRESH_TOKEN_EXPIRES=7
